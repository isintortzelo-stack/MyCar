{
  "expo": {
    "name": "MyCar",
    "slug": "mycar",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon2.png",
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#f59e0b"
        }
      ]
    ],
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.smoti.mycar",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon2.png",
        "backgroundColor": "#0b1220"
      },
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "d5f75603-f1e8-4416-9d05-00ca704b9860"
      }
    },
    "owner": "eazy_g"
  }
}
