{
  "expo": {
    "name": "MyCar",
    "slug": "mycar",
    "version": "0.1.0",
    "orientation": "portrait",
    "plugins": [
      "expo-notifications",
      "./plugins/withMyCarFullScreenAlarms"
    ],
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.smoti.mycar",
      "permissions": [
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "USE_FULL_SCREEN_INTENT",
        "WAKE_LOCK",
        "VIBRATE"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "d5f75603-f1e8-4416-9d05-00ca704b9860"
      }
    },
    "owner": "eazy_g"
  }
}
